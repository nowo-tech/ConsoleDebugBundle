{
    "name": "nowo-tech/console-debug-bundle",
    "description": "Symfony bundle that mirrors cdbg() calls to the browser console for authorized users, even in production.",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": [
        "symfony",
        "symfony-bundle",
        "debug",
        "console",
        "browser",
        "production",
        "dd",
        "dump"
    ],
    "homepage": "https://github.com/nowo-tech/ConsoleDebugBundle",
    "support": {
        "issues": "https://github.com/nowo-tech/ConsoleDebugBundle/issues",
        "source": "https://github.com/nowo-tech/ConsoleDebugBundle",
        "docs": "https://github.com/nowo-tech/ConsoleDebugBundle/tree/main/docs",
        "changelog": "https://github.com/nowo-tech/ConsoleDebugBundle/blob/main/docs/CHANGELOG.md"
    },
    "authors": [
        {
            "name": "Héctor Franco Aceituno",
            "email": "hectorfranco@nowo.tech",
            "homepage": "https://github.com/HecFranco",
            "role": "Developer"
        },
        {
            "name": "Nowo.tech",
            "homepage": "https://nowo.tech"
        }
    ],
    "require": {
        "php": ">=8.1 <8.6",
        "symfony/config": "^6.0 || ^7.0 || ^8.0",
        "symfony/dependency-injection": "^6.0 || ^7.0 || ^8.0",
        "symfony/http-foundation": "^6.0 || ^7.0 || ^8.0",
        "symfony/http-kernel": "^6.0 || ^7.0 || ^8.0",
        "symfony/security-core": "^6.0 || ^7.0 || ^8.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^10.0",
        "rector/rector": "^2.0",
        "symfony/framework-bundle": "^6.0 || ^7.0 || ^8.0",
        "symfony/yaml": "^6.0 || ^7.0 || ^8.0",
        "twig/twig": "^3.12"
    },
    "autoload": {
        "psr-4": {
            "Nowo\\ConsoleDebugBundle\\": "src/"
        },
        "files": [
            "src/Functions.php"
        ],
        "classmap": [
            "NowoConsoleDebugBundle.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Nowo\\ConsoleDebugBundle\\Tests\\": "tests/"
        }
    },
    "archive": {
        "exclude": ["/demo", "/.cursor"]
    },
    "config": {
        "sort-packages": true,
        "root-version": "1.0.0-dev",
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "phpunit --color=always",
        "test-coverage": "phpunit --color=always --coverage-html coverage --coverage-clover coverage.xml --coverage-text",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "rector": "rector process",
        "rector-dry": "rector process --dry-run --no-progress-bar",
        "phpstan": "phpstan analyse --memory-limit=512M",
        "update": "composer update --no-interaction",
        "validate": "composer validate --strict",
        "qa": [
            "@cs-check",
            "@test"
        ]
    },
    "scripts-descriptions": {
        "test": "Run PHPUnit tests",
        "test-coverage": "Run PHPUnit tests with code coverage",
        "cs-check": "Check code style with PHP-CS-Fixer",
        "cs-fix": "Fix code style with PHP-CS-Fixer",
        "rector": "Apply Rector refactoring",
        "rector-dry": "Run Rector in dry-run mode",
        "phpstan": "Run PHPStan static analysis",
        "update": "Update composer.lock (composer update)",
        "validate": "Validate composer.json (composer validate --strict)",
        "qa": "Run all quality assurance checks"
    },
    "suggest": {
        "symfony/security-bundle": "Required in your application for role-based console debug authorization",
        "symfony/flex": "For automatic recipe installation",
        "twig/twig": "Required for {{ cdbg() }} and {% cdbg %} Twig integration"
    }
}
