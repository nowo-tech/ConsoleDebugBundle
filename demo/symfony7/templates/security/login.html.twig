{% extends 'base.html.twig' %}

{% block title %}Login{% endblock %}

{% block body %}
    <div class="card demo-card demo-login-card">
        <div class="card-header text-center">Demo login</div>
        <div class="card-body">
            {% if error %}
                <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            {{ form_start(loginForm, { attr: { class: 'vstack gap-3' } }) }}
                <div>
                    {{ form_label(loginForm._username) }}
                    {{ form_widget(loginForm._username) }}
                    {{ form_errors(loginForm._username) }}
                </div>
                <div>
                    {{ form_label(loginForm._password) }}
                    {{ form_widget(loginForm._password) }}
                    {{ form_errors(loginForm._password) }}
                    <div class="form-text">Password toggle powered by PasswordToggleBundle.</div>
                </div>
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                <button type="submit" class="btn btn-primary w-100">Sign in</button>
            {{ form_end(loginForm) }}

            <p class="text-muted small text-center mt-3 mb-0">Try <code>debugger / debug</code> or <code>viewer / viewer</code>.</p>
        </div>
    </div>
{% endblock %}
