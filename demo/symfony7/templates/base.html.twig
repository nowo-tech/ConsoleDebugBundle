<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Console Debug Demo{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="{{ asset('bundles/nowopasswordtoggle/css/toggle_password.css') }}">
    {{ vite_entry_link_tags('app') }}
</head>
<body>
<nav class="navbar navbar-expand-lg bg-white border-bottom shadow-sm mb-4">
    <div class="container">
        <a class="navbar-brand demo-navbar-brand" href="{{ path('homepage') }}">Console Debug Bundle</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#demoNavbar" aria-controls="demoNavbar" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="demoNavbar">
            <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
                <li class="nav-item"><a class="nav-link" href="{{ path('homepage') }}">Home</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('demo_debug') }}">Examples</a></li>
                {% if app.user %}
                    <li class="nav-item">
                        <span class="badge text-bg-primary demo-badge-role">{{ app.user.userIdentifier }}</span>
                    </li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('logout') }}">Logout</a></li>
                {% else %}
                    <li class="nav-item"><a class="nav-link" href="{{ path('login') }}">Login</a></li>
                {% endif %}
            </ul>
        </div>
    </div>
</nav>

<main class="container pb-5">
    {% block body %}{% endblock %}
</main>

<footer class="container demo-footer pb-4">
    <p class="mb-0">Demo: <code>cdbg()</code> · Bootstrap · Pentatrion Vite · Password Toggle</p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
{{ vite_entry_script_tags('app') }}
</body>
</html>
